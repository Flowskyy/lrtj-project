generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activity_log {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  log_name     String?   @db.VarChar(255)
  description  String    @db.Text
  subject_type String?   @db.VarChar(255)
  event        String?   @db.VarChar(255)
  subject_id   BigInt?   @db.UnsignedBigInt
  causer_type  String?   @db.VarChar(255)
  causer_id    BigInt?   @db.UnsignedBigInt
  properties   Json?
  batch_uuid   String?   @db.Char(36)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)

  @@index([log_name], map: "activity_log_log_name_index")
  @@index([causer_type, causer_id], map: "causer")
  @@index([subject_type, subject_id], map: "subject")
}

model admin_activity_logs {
  id         String      @id
  userId     String?
  action     String      @db.VarChar(100)
  metadata   String      @db.LongText
  createdAt  DateTime    @default(now())
  auth_users auth_users? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

model admin_permissions {
  id                     Int                      @id @default(autoincrement())
  code                   String                   @unique
  label                  String                   @db.VarChar(255)
  admin_role_permissions admin_role_permissions[]
}

model admin_role_permissions {
  roleId            Int
  permissionId      Int
  admin_permissions admin_permissions @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  admin_roles       admin_roles       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "admin_role_permissions_permissionId_fkey")
}

model admin_roles {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  admin_role_permissions admin_role_permissions[]
  auth_users             auth_users[]
}

model api_hits {
  id         Int       @id
  api_name   String?   @db.VarChar(255)
  hit_count  Int?      @default(0) @db.UnsignedInt
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)

  @@index([created_at], map: "created_at")
}

model app_messages {
  id          Int      @id @default(autoincrement())
  user_id     Int
  app         String   @db.VarChar(30)
  description String   @db.Text
  created_at  DateTime @db.DateTime(0)
  parameter   String?  @db.Text
}

model auth_accounts {
  id                    String     @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?    @db.Text
  refreshToken          String?    @db.Text
  idToken               String?    @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?    @db.Text
  createdAt             DateTime   @default(now())
  updatedAt             DateTime
  auth_users            auth_users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model auth_sessions {
  id         String     @id
  userId     String
  token      String     @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  auth_users auth_users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model auth_users {
  id                  String                @id
  name                String
  email               String                @unique
  emailVerified       Boolean               @default(false)
  image               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  roleId              Int?
  admin_activity_logs admin_activity_logs[]
  auth_accounts       auth_accounts[]
  auth_sessions       auth_sessions[]
  admin_roles         admin_roles?          @relation(fields: [roleId], references: [id])

  @@index([roleId], map: "auth_users_roleId_fkey")
}

model auth_verifications {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
}

model banners {
  id          Int       @id @default(autoincrement())
  description String?   @db.Text
  image_url   String    @db.Text
  sequence    Int
  created_at  DateTime? @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
}

model bayarind_binding_states {
  id           BigInt                          @id @default(autoincrement())
  user_id      BigInt
  phone_number String                          @db.VarChar(20)
  state        String                          @unique(map: "state") @db.VarChar(255)
  auth_code    String?                         @db.VarChar(500)
  expires_at   DateTime                        @db.Timestamp(0)
  status       bayarind_binding_states_status? @default(pending)
  created_at   DateTime?                       @default(now()) @db.Timestamp(0)
  updated_at   DateTime?                       @default(now()) @db.Timestamp(0)

  @@index([expires_at], map: "idx_expires_at")
  @@index([state], map: "idx_state")
  @@index([user_id], map: "idx_user_id")
}

model bayarind_callback {
  id         Int       @id @default(autoincrement())
  category   String?   @db.VarChar(255)
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  user_id    Int?
  data       String?   @db.VarChar(255)
}

model bayarind_customer_tokens {
  id              BigInt                                   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id         BigInt                                   @db.UnsignedBigInt
  access_token    String                                   @db.Text
  refresh_token   String?                                  @db.Text
  token_type      String?                                  @default("Bearer") @db.VarChar(50)
  expires_in      Int?
  expires_at      DateTime?                                @db.Timestamp(0)
  scope           String?                                  @db.VarChar(255)
  customer_id     String?                                  @db.VarChar(255)
  phone_number    String?                                  @db.VarChar(20)
  grant_type_used bayarind_customer_tokens_grant_type_used
  raw_response    Json?
  created_at      DateTime?                                @db.Timestamp(0)
  updated_at      DateTime?                                @db.Timestamp(0)

  @@index([expires_at], map: "idx_expires_at")
  @@index([user_id, expires_at], map: "idx_user_expires")
  @@index([user_id], map: "idx_user_id")
}

model bayarind_qr_payment {
  id                    Int       @default(autoincrement())
  bayarind_reference_no String    @db.VarChar(20)
  reference_no          String?   @db.VarChar(20)
  redirect_url          String?   @db.VarChar(255)
  merchant_name         String?   @db.VarChar(50)
  merchant_category     String?   @db.VarChar(50)
  merchant_location     String?   @db.VarChar(50)
  amount                Int?
  response_code         Int?
  valid_time            DateTime? @db.DateTime(0)
  created_at            DateTime? @db.DateTime(0)
  updated_at            DateTime? @db.DateTime(0)
  customer_pan          String?   @db.VarChar(50)
  merchant_pan          String?   @db.VarChar(50)
  paid_time             DateTime? @db.DateTime(0)

  @@id([id, bayarind_reference_no])
}

model daily_benefit {
  id             Int       @id @default(autoincrement())
  editedBy       String?   @db.VarChar(50)
  name           String    @db.VarChar(150)
  image_url      String    @default("") @db.VarChar(150)
  redeem_point   Int       @default(0)
  term_condition String    @db.Text
  created_at     DateTime? @db.DateTime(0)
  updated_at     DateTime? @db.DateTime(0)
  status         Int       @default(1) @db.TinyInt
  start_date     DateTime? @db.DateTime(0)
  end_date       DateTime? @db.DateTime(0)
  is_active      Int?      @db.TinyInt
}

model daily_redem {
  daily_reward_id     Int       @id @default(autoincrement())
  merchant_id         Int
  name                String    @default("") @db.VarChar(255)
  image               String    @default("") @db.VarChar(255)
  description         String    @db.Text
  is_deleted          Boolean   @default(false)
  created_by          String    @db.VarChar(255)
  created_at          DateTime  @db.DateTime(0)
  update_at           String    @db.VarChar(255)
  update_by           DateTime  @db.DateTime(0)
  deleted_at          String    @db.VarChar(255)
  deleted_by          DateTime  @db.DateTime(0)
  redempoin           Float?
  tipe_promo          String?   @default("0") @db.VarChar(10)
  keterangan_tambahan String?   @db.Text
  start_date          DateTime? @db.DateTime(0)
  end_date            DateTime? @db.DateTime(0)

  @@index([merchant_id], map: "merchant_id")
}

model daily_reward {
  daily_reward_id    Int       @id @default(autoincrement())
  merchant_id        Int
  name               String    @default("") @db.VarChar(255)
  image              String    @default("") @db.VarChar(255)
  description        String    @db.Text
  is_deleted         Boolean   @default(false)
  created_by         String    @db.VarChar(255)
  created_at         DateTime  @db.DateTime(0)
  update_at          String    @db.VarChar(255)
  update_by          DateTime  @db.DateTime(0)
  deleted_at         String    @db.VarChar(255)
  deleted_by         DateTime  @db.DateTime(0)
  start_date         DateTime? @db.DateTime(0)
  end_date           DateTime? @db.DateTime(0)
  minimal_perjalanan Float?    @default(0)
  total_qty          Float?    @default(0)

  @@index([merchant_id], map: "merchant_id")
}

model dki_callback {
  id         Int       @id @default(autoincrement())
  category   String?   @db.VarChar(255)
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  user_id    Int?
  data       String?   @db.VarChar(10000)

  @@index([category], map: "category")
  @@index([id], map: "id")
}

model exports {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  completed_at    DateTime? @db.Timestamp(0)
  file_disk       String    @db.VarChar(255)
  file_name       String?   @db.VarChar(255)
  exporter        String    @db.VarChar(255)
  processed_rows  Int       @default(0) @db.UnsignedInt
  total_rows      Int       @db.UnsignedInt
  successful_rows Int       @default(0) @db.UnsignedInt
  user_id         Int
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model failed_import_rows {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  data             Json
  import_id        BigInt    @db.UnsignedBigInt
  validation_error String?   @db.Text
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  imports          imports   @relation(fields: [import_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "failed_import_rows_import_id_foreign")

  @@index([import_id], map: "failed_import_rows_import_id_foreign")
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String   @db.Text
  queue      String   @db.Text
  payload    String   @db.LongText
  exception  String   @db.LongText
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model fare {
  id         Int       @id @default(autoincrement())
  fare       Int?
  max_ticket Int?
  status     String?   @db.VarChar(10)
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
}

model history_redem_poin {
  id                       Int      @id @default(autoincrement())
  merchant_id              Int
  daily_reward_id          Int
  member_id                Int
  member_daily_reward_code String   @db.VarChar(255)
  created_by               String   @db.VarChar(255)
  created_at               DateTime @db.DateTime(0)
  update_by                String   @db.VarChar(255)
  update_at                DateTime @db.DateTime(0)
  point_redem              Float?
  status_scan              Int?     @default(0) @db.TinyInt
  kode_stasiun             String?  @db.VarChar(5)
  merchant_code            String?  @db.VarChar(30)

  @@index([daily_reward_id], map: "daily_reward_id")
  @@index([member_id], map: "member_id")
  @@index([merchant_id], map: "merchant_id")
}

model imports {
  id                 BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  completed_at       DateTime?            @db.Timestamp(0)
  file_name          String               @db.VarChar(255)
  file_path          String               @db.VarChar(255)
  importer           String               @db.VarChar(255)
  processed_rows     Int                  @default(0) @db.UnsignedInt
  total_rows         Int                  @db.UnsignedInt
  successful_rows    Int                  @default(0) @db.UnsignedInt
  user_id            Int
  created_at         DateTime?            @db.Timestamp(0)
  updated_at         DateTime?            @db.Timestamp(0)
  failed_import_rows failed_import_rows[]
}

model job_batches {
  id             String  @id @db.VarChar(255)
  name           String  @db.VarChar(255)
  total_jobs     Int
  pending_jobs   Int
  failed_jobs    Int
  failed_job_ids String  @db.LongText
  options        String? @db.MediumText
  cancelled_at   Int?
  created_at     Int
  finished_at    Int?
}

model kebijakan_privasi {
  id         Int       @id
  judul      String?   @db.VarChar(255)
  keterangan String?   @db.Text
  created_by String?   @db.VarChar(50)
  created_at DateTime? @db.DateTime(0)
}

model lrtjp_earning_history {
  id            BigInt    @id @default(autoincrement())
  user_id       Int
  info          String    @db.Text
  earning_point Decimal   @default(0.000000) @db.Decimal(20, 6)
  category      String    @db.VarChar(50)
  json_params   String?   @db.Text
  created_at    DateTime? @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)

  @@index([user_id], map: "user_id")
}

model masterdata {
  id            Int     @id @default(autoincrement())
  type          String? @db.VarChar(100)
  value_varchar String? @db.VarChar(200)
  value_text    String? @db.Text
}

model member {
  id_member         Int       @id @default(autoincrement())
  nama              String    @default("") @db.VarChar(255)
  email             String    @default("") @db.VarChar(255)
  password          String    @default("") @db.VarChar(255)
  status            Int       @default(1) @db.TinyInt
  date_add          DateTime  @default(now()) @db.DateTime(0)
  alamat            String    @db.VarChar(225)
  date_upd          DateTime? @db.DateTime(0)
  telepon           String    @db.VarChar(225)
  point             Int
  potongan_poin     Float?    @default(0)
  total_trip        Int
  member_level_id   Int       @default(2)
  electronic_money1 String    @db.VarChar(255)
  electronic_money2 String    @db.VarChar(255)
  SYS_CREATED_BY    String    @db.VarChar(255)
  SYS_CREATED_DATE  DateTime  @db.DateTime(0)
  SYS_MODIFIED_BY   String    @db.VarChar(255)
  SYS_MODIFIED_DATE DateTime  @db.DateTime(0)
  verivy_code       String    @db.VarChar(11)
  foto              String    @db.VarChar(225)
  facebookID        String    @db.VarChar(25)
  twitterID         String    @db.VarChar(25)
  googleID          String    @db.VarChar(25)
  profile_img       String?   @db.VarChar(255)
  birthday          DateTime? @db.DateTime(0)
  appleID           String?   @db.VarChar(255)
  nik               String?   @db.VarChar(20)
  tipe_member       String?   @default("0") @db.VarChar(10)
}

